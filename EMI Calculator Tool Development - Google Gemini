<span class="hljs-tag">&lt;<span class="hljs-name">script</span>&gt;</span><span class="javascript">
    <span class="hljs-keyword">const</span> inputs = [
        [<span class="hljs-string">'amount'</span>, <span class="hljs-string">'sld_amount'</span>, <span class="hljs-string">'val_amount'</span>],
        [<span class="hljs-string">'interest'</span>, <span class="hljs-string">'sld_interest'</span>, <span class="hljs-string">'val_interest'</span>],
        [<span class="hljs-string">'tenure'</span>, <span class="hljs-string">'sld_tenure'</span>, <span class="hljs-string">'val_tenure'</span>],
        [<span class="hljs-string">'pf_pct'</span>, <span class="hljs-string">'sld_pf_pct'</span>, <span class="hljs-string">'val_pf_pct'</span>]
    ];

    <span class="hljs-function"><span class="hljs-keyword">function</span> <span class="hljs-title">calculate</span>(<span class="hljs-params"></span>) </span>{
        <span class="hljs-keyword">const</span> P = <span class="hljs-built_in">parseFloat</span>(<span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">'val_amount'</span>).value);
        <span class="hljs-keyword">const</span> annualRate = <span class="hljs-built_in">parseFloat</span>(<span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">'val_interest'</span>).value);
        <span class="hljs-keyword">const</span> years = <span class="hljs-built_in">parseFloat</span>(<span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">'val_tenure'</span>).value);
        <span class="hljs-keyword">const</span> pfPct = <span class="hljs-built_in">parseFloat</span>(<span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">'val_pf_pct'</span>).value);

        <span class="hljs-keyword">const</span> r = annualRate / <span class="hljs-number">12</span> / <span class="hljs-number">100</span>; <span class="hljs-comment">// Monthly rate</span>
        <span class="hljs-keyword">const</span> n = years * <span class="hljs-number">12</span>; <span class="hljs-comment">// Total months</span>

        <span class="hljs-comment">// EMI Calculation (Excel PMT Logic)</span>
        <span class="hljs-keyword">let</span> emi = <span class="hljs-number">0</span>;
        <span class="hljs-keyword">if</span> (r &gt; <span class="hljs-number">0</span>) {
            emi = P * r * <span class="hljs-built_in">Math</span>.pow(<span class="hljs-number">1</span> + r, n) / (<span class="hljs-built_in">Math</span>.pow(<span class="hljs-number">1</span> + r, n) - <span class="hljs-number">1</span>);
        } <span class="hljs-keyword">else</span> {
            emi = P / n;
        }

        <span class="hljs-keyword">const</span> pfAmt = (P * pfPct) / <span class="hljs-number">100</span>;
        <span class="hljs-keyword">const</span> totalPayment = emi * n;
        <span class="hljs-keyword">const</span> totalInterest = totalPayment - P;
        <span class="hljs-keyword">const</span> totalCost = totalInterest + pfAmt;
        <span class="hljs-keyword">const</span> disbursement = P - pfAmt;

        <span class="hljs-comment">// UI Updates</span>
        <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">'res_emi'</span>).innerText = <span class="hljs-string">'Ōé╣'</span> + <span class="hljs-built_in">Math</span>.round(emi).toLocaleString();
        <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">'res_monthly_rate'</span>).innerText = (annualRate / <span class="hljs-number">12</span>).toFixed(<span class="hljs-number">2</span>) + <span class="hljs-string">'%'</span>;
        <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">'res_total_months'</span>).innerText = n;
        <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">'res_pf_amt'</span>).innerText = <span class="hljs-string">'Ōé╣'</span> + <span class="hljs-built_in">Math</span>.round(pfAmt).toLocaleString();
        <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">'res_disbursement'</span>).innerText = <span class="hljs-string">'Ōé╣'</span> + <span class="hljs-built_in">Math</span>.round(disbursement).toLocaleString();
        <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">'res_total_cost'</span>).innerText = <span class="hljs-string">'Ōé╣'</span> + <span class="hljs-built_in">Math</span>.round(totalCost).toLocaleString();
    }

    <span class="hljs-comment">// Link Sliders and Text Boxes</span>
    inputs.forEach(<span class="hljs-function">(<span class="hljs-params">[name, sldId, valId]</span>) =&gt;</span> {
        <span class="hljs-keyword">const</span> sld = <span class="hljs-built_in">document</span>.getElementById(sldId);
        <span class="hljs-keyword">const</span> val = <span class="hljs-built_in">document</span>.getElementById(valId);

        sld.addEventListener(<span class="hljs-string">'input'</span>, <span class="hljs-function">() =&gt;</span> { val.value = sld.value; calculate(); });
        val.addEventListener(<span class="hljs-string">'input'</span>, <span class="hljs-function">() =&gt;</span> { sld.value = val.value; calculate(); });
    });

    <span class="hljs-comment">// Initial Calculation</span>
    calculate();
</span><span class="hljs-tag">&lt;/<span class="hljs-name">script</span>&gt;</span>

