            --text-main: #1e293b;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --accent-bg: #eef2ff;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg);
            color: var(--text-main);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .calculator-card {
            background: var(--card);
            max-width: 900px;
            width: 100%;
            border-radius: 24px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            overflow: hidden;
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
        }

        @media (max-width: 768px) {
            .calculator-card {
                grid-template-columns: 1fr;
            }
        }

        .input-section {
            padding: 40px;
            border-right: 1px solid var(--border);
        }

        .output-section {
            padding: 40px;
            background-color: var(--accent-bg);
            display: flex;
            flex-direction: column;
        }

        h2 {
            font-size: 1.5rem;
            margin-bottom: 24px;
            color: var(--primary);
            font-weight: 700;
        }

        .input-group {
            margin-bottom: 28px;
        }

        .label-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }

        label {
            font-weight: 600;
            font-size: 0.95rem;
            color: var(--text-main);
        }

        .numeric-input {
            width: 120px;
            padding: 8px 12px;
            border: 2px solid var(--border);
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 600;
            text-align: right;
            transition: border-color 0.2s;
        }

        .numeric-input:focus {
            outline: none;
            border-color: var(--primary);
        }

        input[type="range"] {
            width: 100%;
            height: 6px;
            background: #cbd5e1;
            border-radius: 5px;
            outline: none;
            accent-color: var(--primary);
            -webkit-appearance: none;
        }

        .emi-display {
            background: var(--primary);
            color: white;
            padding: 24px;
            border-radius: 16px;
            text-align: center;
            margin-bottom: 24px;
            box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.4);
        }

        .emi-label {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            opacity: 0.9;
        }

        .emi-value {
            font-size: 2.2rem;
            font-weight: 800;
            margin-top: 4px;
        }

        .stats-grid {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .stat-row {
            display: flex;
            justify-content: space-between;
            padding-bottom: 12px;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .stat-label {
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        .stat-value {
            font-weight: 700;
            color: var(--text-main);
        }

        .total-cost-box {
            margin-top: auto;
            padding-top: 20px;
            border-top: 2px dashed #cbd5e1;
        }

        .total-cost-label {
            font-weight: 700;
            color: var(--text-muted);
            font-size: 0.8rem;
            text-transform: uppercase;
        }

        .total-cost-value {
            font-size: 1.5rem;
            font-weight: 800;
            color: #ef4444;
        }
    &lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;

&lt;div class="calculator-card"&gt;
    &lt;div class="input-section"&gt;
        &lt;h2&gt;Loan Details&lt;/h2&gt;
        
        &lt;div class="input-group"&gt;
            &lt;div class="label-row"&gt;
                &lt;label&gt;Loan Amount (Ōé╣)&lt;/label&gt;
                &lt;input type="number" id="num_amt" class="numeric-input" value="1000000"&gt;
            &lt;/div&gt;
            &lt;input type="range" id="rng_amt" min="100000" max="10000000" step="50000" value="1000000"&gt;
        &lt;/div&gt;

        &lt;div class="input-group"&gt;
            &lt;div class="label-row"&gt;
                &lt;label&gt;Tenure (Years)&lt;/label&gt;
                &lt;input type="number" id="num_tenure" class="numeric-input" value="15"&gt;
            &lt;/div&gt;
            &lt;input type="range" id="rng_tenure" min="1" max="30" step="1" value="15"&gt;
        &lt;/div&gt;

        &lt;div class="input-group"&gt;
            &lt;div class="label-row"&gt;
                &lt;label&gt;Interest Rate (% P.A.)&lt;/label&gt;
                &lt;input type="number" id="num_int" class="numeric-input" value="8.5" step="0.1"&gt;
            &lt;/div&gt;
            &lt;input type="range" id="rng_int" min="1" max="25" step="0.1" value="8.5"&gt;
        &lt;/div&gt;

        &lt;div class="input-group"&gt;
            &lt;div class="label-row"&gt;
                &lt;label&gt;Processing Fee (%)&lt;/label&gt;
                &lt;input type="number" id="num_fee" class="numeric-input" value="1" step="0.1"&gt;
            &lt;/div&gt;
            &lt;input type="range" id="rng_fee" min="0" max="5" step="0.1" value="1"&gt;
        &lt;/div&gt;
    &lt;/div&gt;

    &lt;div class="output-section"&gt;
        &lt;div class="emi-display"&gt;
            &lt;div class="emi-label"&gt;Monthly EMI&lt;/div&gt;
            &lt;div class="emi-value" id="disp_emi"&gt;Ōé╣ 0&lt;/div&gt;
        &lt;/div&gt;

        &lt;div class="stats-grid"&gt;
            &lt;div class="stat-row"&gt;
                &lt;span class="stat-label"&gt;Monthly Interest Rate&lt;/span&gt;
                &lt;span class="stat-value" id="disp_monthly_int"&gt;0.71%&lt;/span&gt;
            &lt;/div&gt;
            &lt;div class="stat-row"&gt;
                &lt;span class="stat-label"&gt;Total Months&lt;/span&gt;
                &lt;span class="stat-value" id="disp_total_months"&gt;180&lt;/span&gt;
            &lt;/div&gt;
            &lt;div class="stat-row"&gt;
                &lt;span class="stat-label"&gt;Processing Fee&lt;/span&gt;
                &lt;span class="stat-value" id="disp_fee_amt"&gt;Ōé╣ 10,000&lt;/span&gt;
            &lt;/div&gt;
            &lt;div class="stat-row"&gt;
                &lt;span class="stat-label"&gt;Disbursement&lt;/span&gt;
                &lt;span class="stat-value" id="disp_disbursement" style="color: #10b981;"&gt;Ōé╣ 9,90,000&lt;/span&gt;
            &lt;/div&gt;
        &lt;/div&gt;

        &lt;div class="total-cost-box"&gt;
            &lt;div class="total-cost-label"&gt;Total Interest Payable&lt;/div&gt;
            &lt;div class="stat-value" id="disp_total_int" style="font-size: 1.1rem; margin-bottom: 8px;"&gt;Ōé╣ 0&lt;/div&gt;
            &lt;div class="total-cost-label"&gt;Total Extra Cost&lt;/div&gt;
            &lt;div class="total-cost-value" id="disp_total_cost"&gt;Ōé╣ 0&lt;/div&gt;
        &lt;/div&gt;
    &lt;/div&gt;
&lt;/div&gt;

&lt;script&gt;
    function formatCurrency(num) {
        return 'Ōé╣' + Math.round(num).toLocaleString('en-IN');
    }

    function calculate() {
        const P = parseFloat(document.getElementById('num_amt').value) || 0;
        const years = parseFloat(document.getElementById('num_tenure').value) || 0;
        const annualRate = parseFloat(document.getElementById('num_int').value) || 0;
        const feePct = parseFloat(document.getElementById('num_fee').value) || 0;

        const r = (annualRate / 12) / 100;
        const n = years * 12;

        let emi = 0;
        if (r &gt; 0 &amp;&amp; n &gt; 0) {
            emi = P * r * Math.pow(1 + r, n) / (Math.pow(1 + r, n) - 1);
        } else if (n &gt; 0) {
            emi = P / n;
        }

        const feeAmt = (P * feePct) / 100;
        const totalPayment = emi * n;
        const totalInterest = totalPayment - P;
        const disbursement = P - feeAmt;
        const totalCost = totalInterest + feeAmt;

        document.getElementById('disp_emi').innerText = formatCurrency(emi);
        document.getElementById('disp_monthly_int').innerText = (annualRate / 12).toFixed(2) + '%';
        document.getElementById('disp_total_months').innerText = n;
        document.getElementById('disp_fee_amt').innerText = formatCurrency(feeAmt);
        document.getElementById('disp_disbursement').innerText = formatCurrency(disbursement);
        document.getElementById('disp_total_int').innerText = formatCurrency(totalInterest);
        document.getElementById('disp_total_cost').innerText = formatCurrency(totalCost);
    }

    const controls = [
        { num: 'num_amt', rng: 'rng_amt' },
        { num: 'num_tenure', rng: 'rng_tenure' },
        { num: 'num_int', rng: 'rng_int' },
        { num: 'num_fee', rng: 'rng_fee' }
    ];

    controls.forEach(ctrl =&gt; {
        const numEl = document.getElementById(ctrl.num);
        const rngEl = document.getElementById(ctrl.rng);

        numEl.addEventListener('input', () =&gt; {
            rngEl.value = numEl.value;
            calculate();
        });
        rngEl.addEventListener('input', () =&gt; {
            numEl.value = rngEl.value;
            calculate();
        });
    });

    calculate();
&lt;/script&gt;

&lt;/body&gt;
&lt;/html&gt;
